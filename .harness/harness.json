      ".harness/requirements-decisions.json",
      ".harness/schemas/task.schema.json",
      ".harness/templates/task.json",
      ".harness/templates/requirement.md",
      ".harness/templates/impact-analysis.md",
      ".harness/templates/implementation-plan.md",
      ".harness/templates/test-plan.md",
      ".harness/templates/evidence.md",
      ".harness/templates/review.md",
      ".harness/templates/release-note.md",
      ".harness/core-changes/REGISTER.md",
      ".codex/config.toml",
      ".codex/hooks.json",
      ".codex/hooks/harness_guard.py",
      ".harness/mcp/server.py",
      ".agents/skills/shopxo-nursery-task/SKILL.md",
      ".agents/skills/shopxo-nursery-task/agents/openai.yaml",
      ".agents/skills/shopxo-nursery-task/references/workflow.md",
      ".agents/skills/shopxo-nursery-task/references/requirement-routing.md",
      ".agents/skills/shopxo-nursery-review/SKILL.md",
      ".agents/skills/shopxo-nursery-review/agents/openai.yaml",
      ".agents/skills/shopxo-nursery-review/references/review-checklist.md",
      "scripts/harness.py",
      "scripts/harness_selftest.py",
      "scripts/harness.ps1",
      "scripts/harness.sh",
      ".github/pull_request_template.md",
