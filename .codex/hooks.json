{
  "description": "Project-local ShopXO nursery safety and session hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -u .codex/hooks/harness_guard.py",
            "timeout": 10,
            "statusMessage": "Loading nursery project guardrails"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|shell_command|exec_command|apply_patch|functions\\.shell_command|functions\\.exec)$",
        "hooks": [
          {
            "type": "command",
            "command": "python -u .codex/hooks/harness_guard.py",
            "timeout": 10,
            "statusMessage": "Checking project safety policy"
          }
        ]
      }
    ]
  }
}
